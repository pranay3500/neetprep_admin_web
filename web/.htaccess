# Flutter web SPA: serve index.html for deep links (e.g. /unsubscribe).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Real static files must 404 if missing — do not return index.html for .js/.wasm.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.(js|wasm|json|png|jpg|jpeg|gif|ico|svg|css|html|txt)$ [NC]
  RewriteRule ^ index.html [L]
</IfModule>

# Admin CMS: avoid stale main.dart.js after deploy (service worker + browser cache).
<IfModule mod_headers.c>
  <FilesMatch "\.(html|js|json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
